# TCMB EVDS API anahtarı
# evds.tcmb.gov.tr → Üye Ol → API Anahtarı → buraya yapıştır
TCMB_API_KEY=your_evds_api_key_here

# Firebase Admin SDK servis hesabı JSON dosya yolu
# Varsayılan: projenin bir üst dizinindeki JSON
FIREBASE_CREDENTIALS_PATH=../pay-defteri-firebase-adminsdk-fbsvc-XXXXXXXX.json
